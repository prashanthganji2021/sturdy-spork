{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build": "ng build",
    "build:development": "node node_modules/@angular/cli/bin/ng build -c development",
    "build:production": "node --max_old_space_size=6000 node_modules/@angular/cli/bin/ng build -c production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "start": "ng serve --proxy-config proxy.config.json",
    "s": "ng serve",
    "test:e2e": "playwright test --project=Chromium  --workers=3  103",
    "test:e2e:headed": "playwright test --project=Chromium --headed",
    "test:e2e:debug": "playwright test --project=Chromium --debug  101_ap ",
    "serve:ssr": "node dist/frontend/server/main.js"
  },
